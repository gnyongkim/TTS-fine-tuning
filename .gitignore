# ---------------------------------------------------------------------------
# MeloTTS 파인튜닝 프로젝트 .gitignore
# ---------------------------------------------------------------------------
# 원칙:
#   - 코드/스크립트/설정은 커밋
#   - 데이터셋, 체크포인트, 로그, 가상환경은 커밋하지 않음 (용량 + 라이선스)
# ---------------------------------------------------------------------------

# ---- Python 기본 -----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.python-version

# 가상환경
venv/
.venv/
env/
ENV/
.conda/
*.egg-info/
*.egg

# Jupyter
.ipynb_checkpoints/

# ---- 에디터/IDE ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- 대용량 아티팩트 (핵심) ------------------------------------------------
# MeloTTS 레포 자체는 setup_env.sh가 클론하므로 커밋 안 함
MeloTTS/

# 데이터 — 오디오/트랜스크립트 원본은 모두 제외
data/raw/
data/processed/
data/kss/
data/*.list
data/*.list.cleaned
data/train.list
data/val.list
data/config.json
data/metadata.list
# 단, data/scripts/*.txt (녹음 스크립트, 평가 문장)는 **커밋**
!data/scripts/
!data/scripts/*.txt

# 사전학습 / 파인튜닝 체크포인트
pretrained/
outputs/
*.pth
*.ckpt
*.onnx

# 텐서보드 / 학습 로그
logs/
runs/
*.log
events.out.tfevents.*

# BERT 임베딩 캐시
*.bert.pt

# 오디오 파일 (스크립트 자체가 아니라 데이터)
*.wav
*.mp3
*.flac
*.opus

# ---- Kaggle / HF 시크릿 ----------------------------------------------------
.kaggle/
kaggle.json
.env
.env.*
!.env.example

# ---- 임시 파일 -------------------------------------------------------------
tmp/
temp/
*.tmp
