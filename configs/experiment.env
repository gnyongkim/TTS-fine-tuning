# =============================================================================
#  실험 환경변수 — 본 저장소의 모든 학습 스크립트가 공통으로 읽는다.
#  필요 시 한 곳만 수정하면 됨.
#
#  사용 순서:
#    conda activate GPTSoVits          # 인프라팀이 만든 conda env (대소문자 주의)
#    source configs/experiment.env
#    python scripts/prepare_kss.py
#    python scripts/preprocess_for_training.py
#    bash   scripts/train_s1.sh
#    bash   scripts/train_s2.sh
#
#  주의: 본 파일의 모든 export 는 ${VAR:-default} 형태라,
#       셸에서 미리 export 한 값이 있으면 그 값이 우선됩니다.
# =============================================================================

# ---------- Conda 환경 (안내용 — 자동 활성화는 안 함) ----------
# 인프라팀이 만든 환경 이름. 사용 전에 수동으로 `conda activate GPTSoVits` 필요.
export CONDA_ENV="${CONDA_ENV:-GPTSoVits}"

# ---------- 경로 ----------
# 본 저장소 (git clone 으로 받은 위치)
export REPO_ROOT="${REPO_ROOT:-$HOME/workspace/TTS-fine-tuning}"
# GPT-SoVITS 본체 (인프라팀이 설치한 위치)
export GPT_SOVITS_DIR="${GPT_SOVITS_DIR:-$HOME/GPT-SoVITS}"

# 데이터 (prepare_kss.py 결과)
export DATA_DIR="${DATA_DIR:-$HOME/data/kss_processed}"
export TRAIN_LIST="${TRAIN_LIST:-$DATA_DIR/train.list}"
export VAL_LIST="${VAL_LIST:-$DATA_DIR/val.list}"
export WAV_DIR="${WAV_DIR:-$DATA_DIR/wavs}"

# 실험 출력 (전처리 산출물 + 체크포인트 + 로그)
export EXP_NAME="${EXP_NAME:-kss_baseline}"
export EXP_DIR="${EXP_DIR:-$HOME/data/kss_exp/$EXP_NAME}"

# ---------- 학습 ----------
export GPU_ID="${GPU_ID:-0}"
export IS_HALF="${IS_HALF:-True}"    # fp16 (4070 Ti = True 권장)
export VERSION="${VERSION:-v2}"      # GPT-SoVITS v2
export HF_HOME="${HF_HOME:-$HOME/data/hf_cache}" # HuggingFace 캐시 위치 -> 우리 데이터 폴더 안으로

# ---------- 사전학습 가중치 (확인된 실제 경로 2026-05) ----------
# 인프라팀 설치 후 ls 로 검증된 실제 파일 위치.
# BERT / HuBERT 는 폴더 형태 (transformers from_pretrained 가 폴더를 받음).
# s1/s2G/s2D 는 모두 gsv-v2final-pretrained/ 하위에 위치.
export PRETRAINED_BERT="${PRETRAINED_BERT:-$GPT_SOVITS_DIR/GPT_SoVITS/pretrained_models/chinese-roberta-wwm-ext-large}"
export PRETRAINED_HUBERT="${PRETRAINED_HUBERT:-$GPT_SOVITS_DIR/GPT_SoVITS/pretrained_models/chinese-hubert-base}"
export PRETRAINED_S1="${PRETRAINED_S1:-$GPT_SOVITS_DIR/GPT_SoVITS/pretrained_models/gsv-v2final-pretrained/s1bert25hz-5kh-longer-epoch=12-step=369668.ckpt}"
export PRETRAINED_S2G="${PRETRAINED_S2G:-$GPT_SOVITS_DIR/GPT_SoVITS/pretrained_models/gsv-v2final-pretrained/s2G2333k.pth}"
export PRETRAINED_S2D="${PRETRAINED_S2D:-$GPT_SOVITS_DIR/GPT_SoVITS/pretrained_models/gsv-v2final-pretrained/s2D2333k.pth}"

# ---------- 본 저장소 config ----------
export S1_CONFIG="${S1_CONFIG:-$REPO_ROOT/configs/s1_kss.yaml}"
export S2_CONFIG="${S2_CONFIG:-$REPO_ROOT/configs/s2_kss.json}"
